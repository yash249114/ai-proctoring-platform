{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ai-proctoring-platform.onrender.com/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://ai-proctoring-platform.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
